{
  "id": "map",
  "name": "Kingway Map",
  "version": 8,
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "block": {
      "data": "./assets/map/source/block.geojson",
      "type": "geojson"
    },
    "building": {
      "data": "./assets/map/source/building.geojson",
      "type": "geojson"
    },
    "poi": {
      "data": "./assets/map/source/poi.geojson",
      "type": "geojson"
    },
    "path": {
      "data": "./assets/map/source/path.geojson",
      "type": "geojson"
    },
    "road": {
      "data": "./assets/map/source/road.geojson",
      "type": "geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#1e293b"
      }
    },
    {
      "id": "block",
      "type": "fill",
      "source": "block",
      "paint": {
        "fill-color": "#64748b"
      }
    },
    {
      "id": "road",
      "type": "fill",
      "source": "road",
      "paint": {
        "fill-color": "#94a3b8"
      }
    },
    {
      "id": "road-outline",
      "type": "line",
      "source": "road",
      "paint": {
        "line-color": "#A2ACC1"
      }
    },
    {
      "id": "path",
      "type": "line",
      "source": "path",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#bae6fd",
        "line-opacity": 0.2,
        "line-width": 5
      }
    },
    {
      "id": "building",
      "type": "fill-extrusion",
      "source": "building",
      "paint": {
        "fill-extrusion-color": "#f1f5f9",
        "fill-extrusion-base": 0,
        "fill-extrusion-opacity": 0.75,
        "fill-extrusion-height": ["get", "height"]
      }
    },
    {
      "id": "facility",
      "type": "symbol",
      "source": "poi",
      "layout": {
        "text-field": "{name}\n・",
        "text-size": 12
      },
      "paint": {
        "text-color": "#52525b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      },
      "filter": ["==", "type", "facility"]
    },
    {
      "id": "location",
      "type": "symbol",
      "source": "poi",
      "layout": {
        "text-field": "{name}\n・",
        "text-size": 14
      },
      "paint": {
        "text-color": "#0ea5e9",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      },
      "filter": ["==", "type", "location"]
    }
  ]
}
